<!DOCTYPE html>
<html>
  <head>
    <title inertia><%= content_for(:title) || "Riff Inertia" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%#= stylesheet_link_tag "application" %>
    <%= vite_stylesheet_tag "application" %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "inertia" %>
    <%= inertia_ssr_head %>

  </head>

  <body>
    <% if notice.present? || alert.present? %>
      <div data-flash class="fixed top-4 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2 transition-opacity duration-500">
        <% if notice.present? %>
          <div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 pl-4 pr-2 py-2 rounded-md text-sm shadow-sm">
            <span><%= notice %></span>
            <button type="button" data-flash-close aria-label="Fechar" class="text-green-700 hover:text-green-900 font-bold leading-none px-1">×</button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 pl-4 pr-2 py-2 rounded-md text-sm shadow-sm">
            <span><%= alert %></span>
            <button type="button" data-flash-close aria-label="Fechar" class="text-red-700 hover:text-red-900 font-bold leading-none px-1">×</button>
          </div>
        <% end %>
      </div>
      <script>
        (() => {
          const flash = document.querySelector("[data-flash]");
          if (!flash) return;
          const dismiss = () => {
            flash.style.opacity = "0";
            setTimeout(() => flash.remove(), 500);
          };
          flash.querySelectorAll("[data-flash-close]").forEach(btn => btn.addEventListener("click", dismiss));
          setTimeout(dismiss, 7000);
        })();
      </script>
    <% end %>
    <%= yield %>
  </body>
</html>
