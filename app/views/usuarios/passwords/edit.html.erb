<div class="min-h-screen flex items-center justify-center bg-background px-4 py-12">
  <div class="w-full max-w-md">
    <div class="bg-card rounded-lg border border-border shadow-sm p-8">
      <h2 class="text-2xl font-semibold text-foreground mb-6">Definir nova senha</h2>

      <%= render "usuarios/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-foreground mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-muted-foreground mb-1">
              (<%= @minimum_password_length %> caracteres no mínimo)
            </p>
          <% end %>
          <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                class: "w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-ring" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-foreground mb-1" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-ring" %>
        </div>

        <%= f.submit "Alterar senha",
              class: "w-full bg-primary text-primary-foreground py-2 px-4 rounded-md font-medium hover:opacity-90 transition cursor-pointer" %>
      <% end %>

      <%= render "usuarios/shared/links" %>
    </div>
  </div>
</div>
